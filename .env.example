# ============================================
# Song Automation Pipeline - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# --------------------------------------------
# Application Settings
# --------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --------------------------------------------
# Security (REQUIRED)
# --------------------------------------------
# Generate a secure random key with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=CHANGE_ME_TO_RANDOM_STRING

# JWT Token Settings
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=15          # Access token lifetime (15 minutes)
JWT_REFRESH_EXPIRE_DAYS=7      # Refresh token lifetime (7 days)

# --------------------------------------------
# Admin User (CRITICAL SECURITY!)
# --------------------------------------------
# ⚠️ WARNING: The default password is WEAK and INSECURE!
# Generate a strong password with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_USERNAME=admin
ADMIN_PASSWORD=CHANGE_ME_IMMEDIATELY_TO_SECURE_PASSWORD

# --------------------------------------------
# File Paths (Docker defaults, usually don't change)
# --------------------------------------------
WATCH_FOLDER=/app/generated/songs
DOWNLOAD_FOLDER=/app/downloads
DATA_FOLDER=/app/data

# --------------------------------------------
# Suno Integration (Phase 3)
# --------------------------------------------
SUNO_EMAIL=
SUNO_PASSWORD=

# --------------------------------------------
# YouTube Integration (Phase 5)
# --------------------------------------------
# Get credentials from: https://console.cloud.google.com/
# 1. Create project, enable YouTube Data API v3
# 2. Create OAuth 2.0 credentials (Web application)
# 3. Add redirect URI: http://localhost:8501/oauth/callback
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8501/oauth/callback
YOUTUBE_DEFAULT_PRIVACY=public  # Options: public, unlisted, private

# --------------------------------------------
# Worker Settings
# --------------------------------------------
WORKER_CHECK_INTERVAL=60       # Seconds between queue checks
WORKER_MAX_RETRIES=3          # Max retries for failed tasks

# --------------------------------------------
# Database (SQLite - no configuration needed)
# --------------------------------------------
# DATABASE_URL is auto-configured to: sqlite+aiosqlite:////app/data/songs.db
